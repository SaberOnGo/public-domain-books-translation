{
  "name": "book-epub-project",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "lint:publication": "node scripts/publication_lint.js --write-report",
    "fix:publication": "node scripts/publication_lint.js --fix --write-report",
    "build:epub": "npm run lint:publication && node scripts/build_epub.js",
    "check:epub": "node scripts/run_epubcheck.js"
  },
  "description": "Book-local npm scripts. Shared Node dependencies are installed once under ../node_modules.",
